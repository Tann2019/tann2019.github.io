---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Tanner Steorts">
  <section class="about-hero">
    <div class="about-label animate-in">About</div>
    <h1 class="animate-in" style="animation-delay: 0.1s">
      Building software<br />that <em>matters</em>
    </h1>
  </section>

  <div class="about-grid">
    <div class="about-main animate-in" style="animation-delay: 0.2s">
      <p class="lead">
        Full-stack developer specializing in Laravel + React applications with
        real-time capabilities. I build products that are fast, polished, and fun to use.
      </p>
      <p>
        My career is driven by a strong focus on innovation and problem-solving,
        enabling me to tackle complex challenges with creative and effective approaches.
        I am committed to continuously learning and refining my skills.
      </p>
      <p>
        With a track record of delivering high-quality results, I thrive in dynamic
        environments where I can contribute to the success of ambitious projects and
        initiatives. Currently based in Billings, Montana.
      </p>

      <div class="goals">
        <h3>2026 Goals</h3>
        <ul>
          <li>Ship Gridiron Duels to the App Store and Play Store</li>
          <li>Contribute to open-source Laravel packages</li>
          <li>Write technical posts about real-time app architecture and game design with Laravel</li>
        </ul>
      </div>
    </div>

    <aside class="about-sidebar animate-in" style="animation-delay: 0.3s">
      <div class="sidebar-block">
        <h3>Education</h3>
        <p class="edu-degree">B.S. Computer Science</p>
        <p class="edu-school">Rocky Mountain College</p>
        <p class="edu-year">2019 — 2022</p>
      </div>

      <div class="sidebar-block">
        <h3>Currently</h3>
        <p class="current-role">Support Engineer</p>
        <p class="current-company">Givebutter</p>
      </div>

      <div class="sidebar-block">
        <h3>Links</h3>
        <div class="sidebar-links">
          <a href="https://github.com/Tann2019" target="_blank" rel="noopener">GitHub</a>
          <a href="mailto:tanner.steorts@icloud.com">Email</a>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .about-hero {
    padding: 6rem 0 4rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4rem;
  }

  .about-label {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  h1 em {
    color: var(--accent);
    font-style: italic;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 16rem;
    gap: 6rem;
  }

  .about-main .lead {
    font-size: 1.25rem;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .about-main p {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .about-sidebar {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-top: 0.5rem;
  }

  .sidebar-block h3 {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .edu-degree {
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .edu-school {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.15rem;
  }

  .edu-year {
    font-size: 0.8rem;
    color: var(--text-dim);
  }

  .current-role {
    font-size: 0.95rem;
    color: var(--text);
    font-weight: 500;
    margin-bottom: 0.15rem;
  }

  .current-company {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .sidebar-block a {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .sidebar-block a:hover {
    color: var(--accent);
  }

  .sidebar-links {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .goals {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .goals h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .goals ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .goals li {
    font-size: 0.95rem;
    color: var(--text-muted);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.6;
  }

  .goals li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid var(--accent);
  }

  @media (max-width: 768px) {
    .about-hero {
      padding: 4rem 0 3rem;
      margin-bottom: 3rem;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .about-sidebar {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .sidebar-block {
      min-width: 10rem;
    }
  }
</style>
